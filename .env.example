# ============================================================================
# APP SETTINGS
# ============================================================================

APP_DEBUG=true
APP_DRY_RUN=true
APP_MAX_CONCURRENT_JOBS=1
APP_REPORT_TYPE=weekly

# ============================================================================
# SMTP SETTINGS
# ============================================================================

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=reports@example.com
SMTP_TLS=true
SMTP_SKIP_TLS_VERIFY=false

# ============================================================================
# WEBSITE 1 - Using Share URL (recommended)
# ============================================================================

APP_WEBSITE_1_SHARE_URL=https://umami.eli.pizza/share/YOUR-SHARE-ID
APP_WEBSITE_1_NAME=Your Website
APP_WEBSITE_1_RECIPIENTS=your-email@example.com,your-email2@example.com
APP_WEBSITE_1_TIMEZONE=UTC
APP_WEBSITE_1_DISABLED=false

# ============================================================================
# WEBSITE 2 - Using Username/Password (traditional)
# ============================================================================

# APP_WEBSITE_2_BASE_URL=https://umami.example.com
# APP_WEBSITE_2_ID=your-website-uuid
# APP_WEBSITE_2_USERNAME=your-username
# APP_WEBSITE_2_PASSWORD=your-password
# APP_WEBSITE_2_NAME=Second Website
# APP_WEBSITE_2_RECIPIENTS=user@example.com
# APP_WEBSITE_2_TIMEZONE=America/Los_Angeles
# APP_WEBSITE_2_DISABLED=false

# ============================================================================
# WEBSITE 3 - Using Share ID (explicit share_id)
# ============================================================================

# APP_WEBSITE_3_BASE_URL=https://umami.example.com
# APP_WEBSITE_3_SHARE_ID=your-share-id
# APP_WEBSITE_3_NAME=Third Website
# APP_WEBSITE_3_RECIPIENTS=user@example.com
# APP_WEBSITE_3_TIMEZONE=Europe/Paris
# APP_WEBSITE_3_DISABLED=false

# Notes:
# - Share URLs are preferred - no credentials needed
# - APP_WEBSITE_*, where * is a number starting from 1
# - To disable a site, set DISABLED=true or omit the entry
# - RECIPIENTS can be comma-separated for multiple emails
# - TIMEZONE can be any IANA timezone (e.g., UTC, America/New_York, Asia/Kolkata)